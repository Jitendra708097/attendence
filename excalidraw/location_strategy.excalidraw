    },
    {
      "id": "05cb6f8e",
      "type": "text",
      "x": 772,
      "y": 2257,
      "width": 400,
      "height": 120.0,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "text": "Even with no geo-fence validation, storing coordinates serves:\n\n\u2022 Dispute resolution: 'I was working, here's proof'\n\u2022 Audit: admin can see check-in location pattern\n\u2022 HR: confirms employee is in the same timezone\n\u2022 Future feature: detect unusual locations (vacation travel)\n\n\u2192 Store always. Validate only when is_remote = false.",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "groupIds": []
    },
    {
      "id": "102fe7a7",
