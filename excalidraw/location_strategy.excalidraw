    },
    {
      "id": "d43d3979",
      "type": "text",
      "x": 812,
      "y": 2747,
      "width": 460,
      "height": 165.0,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "text": "iOS has NO mock location flag.\nThis means on iPhone:\n\n\u2022 Layer 1 (OS flag) doesn't work\n\u2022 Must rely on Layer 2 (DevMode) + Layer 3 (Velocity) + Layer 4 (Pattern)\n\n\u2192 Your velocity check on the backend becomes\n   the MOST IMPORTANT anti-spoof for iOS users.\n\n\u2192 Ensure server-side velocity check runs on\n   EVERY check-in regardless of platform.",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "groupIds": []
    },
    {
      "id": "7e426af5",
