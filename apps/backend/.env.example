# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendease_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-256-bit-jwt-secret-here-change-in-production
JWT_REFRESH_SECRET=your-different-256-bit-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REKOGNITION_COLLECTION_ID=attendease-faces

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@attendease.com

# SMS Gateway
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# Frontend URLs
ADMIN_WEB_URL=http://localhost:3001
SUPERADMIN_WEB_URL=http://localhost:3002

# Feature Flags
FACE_CLOUD_ENABLED=true
FACE_CLOUD_THRESHOLD=0.90
OFFLINE_SYNC_ENABLED=true

